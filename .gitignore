# Skill provenance lock (per-repo, not committed)
skills.lock

# Scratch / temp files
tmp_*
*.tmp
.tmp-*
.pending-*.sh
.run-*.sh
.*-tmp.md
.*-draft.md
.*-msg.txt
*_msg.txt
*_raw.txt

# Leaked creds scratch
.xai_key
.ghtoken

# Python bytecode
__pycache__/
*.pyc

# Node
node_modules/

# Stale artifacts
.external-work
.vuln-scan/
.atlas-cache/

# Quartz build output (we ship to docs/universe/ instead)
quartz/node_modules/
quartz/public/
quartz/.quartz-cache/
quartz/.quartz/

