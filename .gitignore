# macOS
.DS_Store

# Secrets & local env
.env
.env.local
.env.*.local

# Claude Code local state
.claude/

# Caches (regenerated per run)
.xai-cache/
.bankr-cache/
.pending-notify/
.pending-replicate/
.pending-supernotes/
.pending-deploy/
.pending-devto/
.pending-farcaster/
